{
  "manifest_version": 3,
  "name": "ResumeAI",
  "version": "1.0.0",
  "description": "Extensão para resumir páginas, PDFs e vídeos com IA.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "sidePanel",
    "clipboardWrite"

  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "<all_urls>"
  ],
  "action": {
    "default_title": "ResumeAI",
    "default_icon": "icons/icon.png"
  },
  "icons": {
    "128": "icons/icon.png"
  },
  "side_panel": {
    "default_path": "app.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}